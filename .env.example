# Copy this file to .env and fill in the values.
# cp .env.example .env

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string
###< symfony/framework-bundle ###

# Redis
REDIS_URL=redis://localhost:6379

# Contentful (https://app.contentful.com -> Space -> Settings -> API keys)
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_TOKEN=your_delivery_api_token

# Storyblok (https://app.storyblok.com -> Settings -> Access Tokens)
STORYBLOK_TOKEN=your_preview_or_public_token

# Sanity (https://sanity.io/manage -> Project -> API)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_TOKEN=

# WordPress (self-hosted, e.g. via Docker)
WORDPRESS_BASE_URL=http://localhost:8081

# Strapi v4 (self-hosted, e.g. via Docker)
STRAPI_BASE_URL=http://localhost:1337

# Webhook HMAC secrets (set these in your CMS webhook config)
WEBHOOK_SECRET_WORDPRESS=change_me
WEBHOOK_SECRET_STRAPI=change_me

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###
